# Copy to .env.local and fill in your SPA app registration values.
#
# Register a Single-page application in Entra ID with a redirect URI of your
# deployment origin (e.g. http://localhost:3000 and your Vercel URL), then grant
# admin consent for the delegated READ scopes listed in the README.

# Application (client) ID of the SPA app registration (required).
NEXT_PUBLIC_AAD_CLIENT_ID=

# Tenant id, or "organizations" for any work/school tenant (optional).
NEXT_PUBLIC_AAD_TENANT_ID=organizations
